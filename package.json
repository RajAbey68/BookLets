{
  "name": "booklets",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:coverage": "vitest run --coverage",
    "test:integration:setup": "bash scripts/test-integration-setup.sh",
    "test:integration": "npm run test:integration:setup && DATABASE_URL=postgresql://postgres:test@localhost:55432/booklets_test vitest run --config vitest.integration.config.ts",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:setup": "prisma db push && prisma db seed"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "adm-zip": "^0.6.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.0",
    "gray-matter": "^4.0.3",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "pg": "^8.20.0",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "@hono/node-server": "^1.19.13"
  }
}
