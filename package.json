    "db:seed": "prisma db seed",
    "db:setup": "prisma db push && prisma db seed"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.6.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.0.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vitest": "^3.0.0"
