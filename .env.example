# ── Database ────────────────────────────────────────────────────────────────
# Supabase connection string (Transaction mode via PgBouncer on port 6543).
# Add ?pgbouncer=true&connection_limit=1 so Prisma works in serverless.
# NOTE: the RUNTIME uses the pg driver adapter (src/lib/prisma.ts), which
# IGNORES a `schema=` query param — the booklets search_path is set there
# via the `options=-c search_path=booklets,public` startup parameter.
# The Prisma CLI (`prisma db push` / `migrate` via prisma.config.ts) does NOT
# use that adapter and DOES honour `schema=` — keep it in the URL so CLI
# operations target the booklets schema instead of public.
# Needed at RUNTIME only; `next build` and `prisma generate` do not connect.
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&schema=booklets"

# ── Auth.js ──────────────────────────────────────────────────────────────────
# REQUIRED in production. Auth.js/NextAuth v5 needs a non-empty secret to
# sign session JWTs — an empty/unset value breaks every sign-in.
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# AUTH_URL is OPTIONAL on Vercel (the host is inferred). If you do set it
# (or the legacy NEXTAUTH_URL), it MUST be an absolute URL including the
# scheme, e.g. "https://booklets.vercel.app". A value without "https://"
# throws `TypeError: Invalid URL` inside NextAuth on every request and
# 500s the whole site (MIDDLEWARE_INVOCATION_FAILED).
# AUTH_URL=""

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Redirect URI to add: https://<your-vercel-url>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Comma-separated email allow-list. Only listed emails can sign in.
# Required in production: deploys with this unset/empty refuse every
# sign-in by design (fail-closed). Leave blank in local dev to disable
# the gate.
AUTH_ALLOWED_EMAILS=""

# ── Optional: Hostaway integration ───────────────────────────────────────────
# Required only if syncing live booking data from Hostaway. All three or
# none — in production, clicking Sync with any of these unset THROWS rather
# than degrading (src/lib/hostaway.service.ts fails closed by design). Do not
# set just one or two expecting a partial/best-effort sync.
# HOSTAWAY_CLIENT_ID=""
# HOSTAWAY_CLIENT_SECRET=""
# HOSTAWAY_ACCOUNT_ID=""

# ── Optional: AI receipt extraction ──────────────────────────────────────────
# Required only for the receipt uploader feature.
# GEMINI_API_KEY=""
#
# OCR microservice — defaults to production if unset
# OCR_MICROSERVICE_URL="https://ocr-microservice-gamma.vercel.app"

# ── Optional: S1b staging→ledger bridge ──────────────────────────────────────
# Organization id the org-less raj_fin_track.ocr_receipts staging pool is
# bound to; /api/ingest/ocr-bridge fails closed (503) while this is unset.
# OCR_BRIDGE_ORG_ID=""

# ── Optional: blog ───────────────────────────────────────────────────────────
# Absolute site origin used to build absolute /blog RSS + sitemap links.
# Defaults to the production URL if unset. The /blog pages themselves need
# nothing else — they just read content/blog/*.md.
# BLOG_SITE_URL=""
